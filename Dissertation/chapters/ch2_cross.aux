\@writefile{toc}{\contentsline {subsection}{\numberline {2.2.4}Interpreting results}{25}{subsection.2.2.4}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.5}{\ignorespaces Four plots of conditional marginal effects. Each plot represents average values across both relevant interaction terms. In (A), the plot shows the average of two separate conditional marginal effects: that of \textit  {hostile} $\times $ \textit  {depressed} on \textit  {nervous}, as well as for \textit  {nervous} $\times $ \textit  {depressed} on \textit  {hostile}. In (B), the plot shows the average of the conditional marginal effects of \textit  {sleepy} $\times $ \textit  {depressed} on \textit  {nervous}, as well as for \textit  {nervous} $\times $ \textit  {depressed} on \textit  {sleepy}. In (C), the plot shows the average of the conditional marginal effects of \textit  {sleepy} $\times $ \textit  {depressed} on \textit  {hostile}, as well as for \textit  {hostile} $\times $ \textit  {depressed} on \textit  {sleepy}. In (D), this is the average conditional marginal effects of \textit  {lonely} $\times $ \textit  {depressed} on \textit  {sleepy} and \textit  {sleepy} $\times $ \textit  {depressed} on \textit  {lonely}.\relax }}{26}{figure.caption.9}}
\newlabel{fig:conds}{{2.5}{26}{Four plots of conditional marginal effects. Each plot represents average values across both relevant interaction terms. In (A), the plot shows the average of two separate conditional marginal effects: that of \textit {hostile} $\times $ \textit {depressed} on \textit {nervous}, as well as for \textit {nervous} $\times $ \textit {depressed} on \textit {hostile}. In (B), the plot shows the average of the conditional marginal effects of \textit {sleepy} $\times $ \textit {depressed} on \textit {nervous}, as well as for \textit {nervous} $\times $ \textit {depressed} on \textit {sleepy}. In (C), the plot shows the average of the conditional marginal effects of \textit {sleepy} $\times $ \textit {depressed} on \textit {hostile}, as well as for \textit {hostile} $\times $ \textit {depressed} on \textit {sleepy}. In (D), this is the average conditional marginal effects of \textit {lonely} $\times $ \textit {depressed} on \textit {sleepy} and \textit {sleepy} $\times $ \textit {depressed} on \textit {lonely}.\relax }{figure.caption.9}{}}
